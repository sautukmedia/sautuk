# Backend Server Configuration
PORT=3000
NODE_ENV=development

# Database Settings (Local PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# Authentication Settings
JWT_SECRET="super-secret-jwt-key"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS Configuration
FRONTEND_URL="http://localhost:5173"

# Whitelisted Single Admin Account (Placeholders)
ADMIN_EMAIL="admin-email-here@domain.com"
ADMIN_PASSWORD="choose-a-strong-password-here"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

